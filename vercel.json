{
  "version": 2,
  "functions": {
    "api/index.ts": {
      "includeFiles": "apps/api/prisma/**"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.ts"
    }
  ],
  "crons": [
    {
      "path": "/api/appointments/trigger-reminders",
      "schedule": "0 * * * *"
    }
  ]
}
