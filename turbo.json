{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env", "**/.env.local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"],
      "env": [
        "DATABASE_URL",
        "DIRECT_URL",
        "JWT_SECRET",
        "JWT_REFRESH_SECRET",
        "SUPABASE_URL",
        "SUPABASE_SERVICE_KEY",
        "CRON_SECRET",
        "ALLOWED_ORIGINS",
        "FRONTEND_URL",
        "SMTP_HOST",
        "SMTP_PORT",
        "SMTP_USER",
        "SMTP_PASS"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "clean": {
      "cache": false
    }
  }
}
