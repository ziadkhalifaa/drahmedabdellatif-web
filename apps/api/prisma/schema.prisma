// Run this after deploying:
// npx prisma migrate dev --name add_payments --schema=apps/api/prisma/schema.prisma

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  admin
  editor
  patient
}

enum AppointmentType {
  ONLINE
  IN_CLINIC
}

enum AppointmentStatus {
  pending
  approved
  rejected
  completed
  cancelled
}

enum BlogPostStatus {
  draft
  published
}

model User {
  id                    String         @id @default(cuid())
  email                 String         @unique
  password              String
  name                  String
  phone                 String?
  isPhoneVerified       Boolean        @default(false)
  phoneVerificationCode String?
  isEmailVerified       Boolean        @default(false)
  emailVerificationCode String?
  emailVerificationExpiry DateTime?
  passwordResetCode      String?
  passwordResetExpiry    DateTime?
  role                  UserRole       @default(patient)
  appointments          Appointment[]
  medicalReports        MedicalReport[]
  refreshTokens         RefreshToken[]
  auditLogs             AuditLog[]
  prescriptions         Prescription[]
  payments              Payment[]
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @default(now()) @updatedAt
}

model Appointment {
  id             String            @id @default(cuid())
  type           AppointmentType   @default(IN_CLINIC)
  patientId      String?
  patient        User?             @relation(fields: [patientId], references: [id])
  // Guest info (fallback)
  guestName      String?
  guestPhone     String?
  guestEmail     String?
  
  date           DateTime
  timeSlot       String
  status         AppointmentStatus @default(pending)
  notes          String?
  
  // Video Meeting Info
  meetingId      String?           @unique
  meetingUrl     String?
  
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @default(now()) @updatedAt
  review         AppointmentReview?
  prescription   Prescription?
  payments       Payment[]
}

model MedicalReport {
  id          String   @id @default(cuid())
  patientId   String
  patient     User     @relation(fields: [patientId], references: [id])
  title       String
  description String?
  fileUrl     String?  // Link to PDF/Image
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}

model BlogPost {
  id                String         @id @default(cuid())
  titleAr           String
  titleEn           String
  slugAr            String         @unique
  slugEn            String         @unique
  contentAr         String
  contentEn         String
  excerptAr         String?
  excerptEn         String?
  metaTitleAr       String?
  metaTitleEn       String?
  metaDescriptionAr String?
  metaDescriptionEn String?
  keywords          String?
  categoryId        String?
  category          Category?      @relation(fields: [categoryId], references: [id])
  tags              BlogTag[]
  status            BlogPostStatus @default(draft)
  featuredImage     String?
  createdAt         DateTime       @default(now())

  updatedAt         DateTime       @default(now()) @updatedAt
}

model Category {
  id     String     @id @default(cuid())
  nameAr String
  nameEn String
  slugAr String     @unique
  slugEn String     @unique
  posts  BlogPost[]
}

model Tag {
  id     String    @id @default(cuid())
  nameAr String
  nameEn String
  slugAr String    @unique
  slugEn String    @unique
  posts  BlogTag[]
}

model BlogTag {
  blogId String
  tagId  String
  blog   BlogPost @relation(fields: [blogId], references: [id], onDelete: Cascade)
  tag    Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([blogId, tagId])
}

model Service {
  id            String   @id @default(cuid())
  titleAr       String
  titleEn       String
  descriptionAr String
  descriptionEn String
  icon          String
  image         String?
  order         Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt
}


model Testimonial {
  id           String   @id @default(cuid())
  patientName  String
  patientAvatar String?
  content      String
  rating       Int
  isApproved   Boolean  @default(false)
  isVisible    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Media {
  id        String   @id @default(cuid())
  type      String   // "image" or "video"
  url       String
  titleAr   String?
  titleEn   String?
  categoryAr String?
  categoryEn String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model SiteSettings {
  key   String @id
  value Json
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  type      String
  payload   Json
  createdAt DateTime @default(now())
}

model WorkingHours {
  id           String   @id @default(cuid())
  dayOfWeek    Int      // 0=Sunday, 1=Monday, ..., 6=Saturday
  startTime    String   // "16:00"
  endTime      String   // "20:00"
  slotDuration Int      @default(30) // minutes
  isActive     Boolean  @default(true)
}

model BlockedSlot {
  id        String   @id @default(cuid())
  date      DateTime
  timeSlot  String?  // null = اليوم كله محجوز
  reason    String?
  createdAt DateTime @default(now())
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model AppointmentReview {
  id            String      @id @default(cuid())
  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  rating        Int         // 1-5
  comment       String?
  isPublic      Boolean     @default(false)
  createdAt     DateTime    @default(now())
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}


model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String   // e.g., "DELETE_POST", "UPDATE_SETTINGS"
  resource  String?  // e.g., "BlogPost", "SiteSettings"
  details   Json?    // Any extra data
  ip        String?
  createdAt DateTime @default(now())
}

model Prescription {
  id            String      @id @default(cuid())
  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  patientId     String
  patient       User        @relation(fields: [patientId], references: [id])
  
  diagnosisAr   String?
  diagnosisEn   String?
  medications   Json        // List of { name, dosage, duration, notes }
  instructionsAr String?
  instructionsEn String?
  
  isIssued      Boolean     @default(false)
  issuedAt      DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @default(now()) @updatedAt
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

model Payment {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  appointmentId   String?
  appointment     Appointment?  @relation(fields: [appointmentId], references: [id])
  paymobOrderId   String?       @unique
  amount          Float         // Amount in EGP
  currency        String        @default("EGP")
  status          PaymentStatus @default(PENDING)
  transactionId   String?       // Paymob transaction ID
  paymentMethod   String?       // e.g. "card", "wallet"
  metadata        Json?         // Extra Paymob response data
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @default(now()) @updatedAt
}
