generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x"]
  engineType    = "binary"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                      String          @id @default(cuid())
  email                   String          @unique
  password                String
  name                    String
  phone                   String?
  isPhoneVerified         Boolean         @default(false)
  phoneVerificationCode   String?
  isEmailVerified         Boolean         @default(false)
  emailVerificationCode   String?
  role                    UserRole        @default(patient)
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @default(now()) @updatedAt
  emailVerificationExpiry DateTime?
  passwordResetCode       String?
  passwordResetExpiry     DateTime?
  address                 String?
  dateOfBirth             DateTime?
  gender                  String?
  appointments            Appointment[]
  auditLogs               AuditLog[]
  medicalReports          MedicalReport[]
  payments                Payment[]
  prescriptions           Prescription[]
  refreshTokens           RefreshToken[]
}

model Clinic {
  id           String               @id @default(cuid())
  nameAr       String
  nameEn       String
  addressAr    String
  addressEn    String
  phone        String?
  mapUrl       String?
  imageUrl     String?
  isActive     Boolean              @default(true)
  order        Int                  @default(0)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @default(now()) @updatedAt
  workingHours ClinicWorkingHours[]
  blockedSlots ClinicBlockedSlot[]
  appointments Appointment[]
}

model ClinicWorkingHours {
  id           String  @id @default(cuid())
  clinicId     String
  dayOfWeek    Int     // 0=Sunday ... 6=Saturday
  startTime    String  // "09:00"
  endTime      String  // "17:00"
  slotDuration Int     @default(30) // minutes
  isActive     Boolean @default(true)
  clinic       Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([clinicId, dayOfWeek])
}

model ClinicBlockedSlot {
  id        String   @id @default(cuid())
  clinicId  String
  date      DateTime
  timeSlot  String?  // null = block entire day
  reason    String?
  createdAt DateTime @default(now())
  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
}

model Appointment {
  id                 String               @id @default(cuid())
  type               AppointmentType      @default(IN_CLINIC)
  patientId          String?
  guestName          String?
  guestPhone         String?
  guestEmail         String?
  date               DateTime
  timeSlot           String
  status             AppointmentStatus    @default(pending)
  notes              String?
  meetingId          String?              @unique
  meetingUrl         String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @default(now()) @updatedAt
  cancellationReason String?
  clinicId           String?
  paymentMethod      PaymentMethodType    @default(NONE)
  paymentProofUrl    String?
  paymentSenderNum   String?
  paymentStatus      PaymentConfirmStatus @default(NOT_REQUIRED)
  paymentNote        String?
  clinic             Clinic?              @relation(fields: [clinicId], references: [id])
  patient            User?                @relation(fields: [patientId], references: [id])
  review             AppointmentReview?
  payments           Payment[]
  prescription       Prescription?
}

model MedicalReport {
  id          String   @id @default(cuid())
  patientId   String
  title       String
  description String?
  fileUrl     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  patient     User     @relation(fields: [patientId], references: [id])
}

model BlogPost {
  id                String         @id @default(cuid())
  titleAr           String
  titleEn           String
  slugAr            String         @unique
  slugEn            String         @unique
  contentAr         String
  contentEn         String
  excerptAr         String?
  excerptEn         String?
  metaTitleAr       String?
  metaTitleEn       String?
  metaDescriptionAr String?
  metaDescriptionEn String?
  keywords          String?
  categoryId        String?
  status            BlogPostStatus @default(draft)
  featuredImage     String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @default(now()) @updatedAt
  showOnHomepage    Boolean        @default(false)
  category          Category?      @relation(fields: [categoryId], references: [id])
  tags              BlogTag[]
}

model Category {
  id     String     @id @default(cuid())
  nameAr String
  nameEn String
  slugAr String     @unique
  slugEn String     @unique
  posts  BlogPost[]
}

model Tag {
  id     String    @id @default(cuid())
  nameAr String
  nameEn String
  slugAr String    @unique
  slugEn String    @unique
  posts  BlogTag[]
}

model BlogTag {
  blogId String
  tagId  String
  blog   BlogPost @relation(fields: [blogId], references: [id], onDelete: Cascade)
  tag    Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([blogId, tagId])
}

model Service {
  id                String   @id @default(cuid())
  titleAr           String
  titleEn           String
  descriptionAr     String
  descriptionEn     String
  icon              String
  image             String?
  order             Int      @default(0)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @default(now()) @updatedAt
  slug              String?  @unique
  metaDescriptionAr String?
  metaDescriptionEn String?
  metaTitleAr       String?
  metaTitleEn       String?
}

model Testimonial {
  id             String   @id @default(cuid())
  patientName    String
  patientAvatar  String?
  content        String
  rating         Int
  isApproved     Boolean  @default(false)
  isVisible      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt
  isSuccessStory Boolean  @default(false)
  patientCity    String?
  patientImages  String[] @default([])
  storyContent   String?
  storyContentEn String?
  storyTitle     String?
  storyTitleEn   String?
  treatmentType  String?
}

model HeroSlide {
  id         String   @id @default(cuid())
  titleAr    String
  titleEn    String
  subtitleAr String
  subtitleEn String
  image      String
  isPortrait Boolean  @default(false)
  order      Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
}

model Technique {
  id                String  @id @default(cuid())
  titleAr           String
  titleEn           String
  descriptionAr     String
  descriptionEn     String
  image             String?
  slug              String  @unique
  order             Int     @default(0)
  isActive          Boolean @default(true)
  metaDescriptionAr String?
  metaDescriptionEn String?
  metaTitleAr       String?
  metaTitleEn       String?
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Media {
  id         String   @id @default(cuid())
  type       String
  url        String
  titleAr    String?
  titleEn    String?
  categoryAr String?
  categoryEn String?
  order      Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
}

model SiteSettings {
  key   String @id
  value Json
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  type      String
  payload   Json
  createdAt DateTime @default(now())
}

model WorkingHours {
  id           String  @id @default(cuid())
  dayOfWeek    Int
  startTime    String
  endTime      String
  slotDuration Int     @default(30)
  isActive     Boolean @default(true)
}

model BlockedSlot {
  id        String   @id @default(cuid())
  date      DateTime
  timeSlot  String?
  reason    String?
  createdAt DateTime @default(now())
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model AppointmentReview {
  id            String      @id @default(cuid())
  appointmentId String      @unique
  rating        Int
  comment       String?
  isPublic      Boolean     @default(false)
  createdAt     DateTime    @default(now())
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  resource  String?
  details   Json?
  ip        String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Prescription {
  id             String      @id @default(cuid())
  appointmentId  String      @unique
  patientId      String
  diagnosisAr    String?
  diagnosisEn    String?
  medications    Json
  instructionsAr String?
  instructionsEn String?
  isIssued       Boolean     @default(false)
  issuedAt       DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @default(now()) @updatedAt
  appointment    Appointment @relation(fields: [appointmentId], references: [id])
  patient        User        @relation(fields: [patientId], references: [id])
}

model Payment {
  id              String            @id @default(cuid())
  userId          String
  appointmentId   String?
  paymobOrderId   String?           @unique
  amount          Float
  currency        String            @default("EGP")
  transactionId   String?
  paymentMethod   String?
  metadata        Json?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @default(now()) @updatedAt
  status          PaymentStatus     @default(PENDING)
  method          PaymentMethodType @default(PAYMOB)
  proofImageUrl   String?
  senderPhone     String?
  adminNote       String?
  confirmedAt     DateTime?
  confirmedById   String?
  appointment     Appointment?      @relation(fields: [appointmentId], references: [id])
  user            User              @relation(fields: [userId], references: [id])
}

enum UserRole {
  admin
  editor
  patient
}

enum AppointmentType {
  ONLINE
  IN_CLINIC
}

enum AppointmentStatus {
  pending
  approved
  rejected
  completed
  cancelled
}

enum BlogPostStatus {
  draft
  published
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum PaymentMethodType {
  NONE
  INSTAPAY
  VODAFONE_CASH
  PAYMOB
  CASH
}

enum PaymentConfirmStatus {
  NOT_REQUIRED
  PENDING_REVIEW
  CONFIRMED
  REJECTED
}
