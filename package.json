{
  "name": "dr-ahmed-platform",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json}\"",
    "db:generate": "pnpm --filter @dr-ahmed/api run prisma:generate",
    "db:push": "pnpm --filter @dr-ahmed/api run prisma:push",
    "db:migrate": "pnpm --filter @dr-ahmed/api run prisma:migrate",
    "db:seed": "pnpm --filter @dr-ahmed/api run prisma:seed",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "turbo": "^2.9.10",
    "typescript": "^5.9.0"
  },
  "packageManager": "pnpm@11.0.8",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@types/sharp": "^0.32.0",
    "@types/uuid": "^11.0.0",
    "axios": "^1.16.0",
    "sharp": "^0.34.5",
    "uuid": "^14.0.0"
  }
}
